# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server
PORT=3000
JWT_SECRET=your_jwt_secret_key_here

# MongoDB
MONGO_URI=mongodb://localhost:27017/geovision

# AI Configuration - OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# AI Configuration - Google Vision (Optional)
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-credentials.json

# AI Configuration - Claude (Optional Alternative)
CLAUDE_API_KEY=sk-your-claude-api-key-here

# Feature Flags
AI_OCR_ENABLED=true
AI_VERIFICATION_ENABLED=true
AI_VALUATION_ENABLED=false
AI_FRAUD_ENABLED=true

# Google Drive Configuration (for document uploads)
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
GOOGLE_DRIVE_CREDENTIALS=path/to/google-drive-credentials.json
